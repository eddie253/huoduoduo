{
  "name": "huoduoduo-refactor-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo root for Flutter + BFF migration baseline.",
  "workspaces": [
    "apps/bff_gateway"
  ],
  "scripts": {
    "bff:dev": "npm --workspace apps/bff_gateway run start:dev",
    "bff:lint": "npm --workspace apps/bff_gateway run lint",
    "bff:build": "npm --workspace apps/bff_gateway run build",
    "bff:start:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-local-bff.ps1",
    "bff:test": "npm --workspace apps/bff_gateway run test",
    "bff:test:coverage": "npm --workspace apps/bff_gateway run test:coverage -- --runInBand",
    "bff:route-diff": "node ops/ci/check-route-diff.js",
    "bff:error-code-map": "node ops/ci/check-error-code-map.js",
    "bff:verify": "npm run bff:route-diff && npm run bff:error-code-map && npm run bff:lint && npm run bff:test -- --runInBand && npm run bff:build",
    "mobile:analyze": "cd apps/mobile_flutter && flutter analyze",
    "mobile:test": "cd apps/mobile_flutter && flutter test",
    "mobile:build:apk:debug": "cd apps/mobile_flutter && flutter build apk --debug",
    "mobile:build:ios:nocodesign": "cd apps/mobile_flutter && flutter build ios --no-codesign",
    "mobile:verify": "npm run mobile:analyze && npm run mobile:test && npm run mobile:build:apk:debug",
    "mobile:test:coverage": "node ops/ci/run-flutter-coverage.js",
    "mobile:coverage:check": "node ops/ci/check-flutter-coverage.js apps/mobile_flutter/coverage/lcov.info 50",
    "mobile:test:login-it": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-mobile-login-it.ps1",
    "mobile:log:bridge": "powershell -ExecutionPolicy Bypass -File .\\scripts\\tail-mobile-bridge-log.ps1",
    "coverage:collect": "node ops/ci/collect-coverage.js --component summary",
    "coverage:collect:all": "node ops/ci/collect-coverage.js --component all",
    "coverage:html": "node ops/ci/generate-coverage-html.js",
    "coverage:verify": "npm run bff:test:coverage && npm run mobile:test:coverage && npm run mobile:coverage:check && npm run coverage:collect:all && npm run coverage:html",
    "wave2:uat-smoke": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-wave2-uat-smoke.ps1"
  }
}
