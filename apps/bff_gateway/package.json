{
  "name": "bff_gateway",
  "version": "0.1.0",
  "description": "Huoduoduo Express BFF gateway with transitional token broker and SOAP adapters.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "check:route-diff": "node ../../ops/ci/check-route-diff.js",
    "audit:high": "node -e \"const cp=require('child_process'); cp.spawnSync('npm',['audit','--audit-level=high'],{stdio:'inherit',shell:true}); process.exit(0);\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/throttler": "^6.2.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fast-xml-parser": "^4.5.0",
    "helmet": "^8.0.0",
    "redis": "^4.7.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.16.11",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageProvider": "v8",
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/coverage/**"
    ],
    "coveragePathIgnorePatterns": [
      "/coverage/"
    ],
    "coverageDirectory": "../coverage",
    "coverageReporters": [
      "text-summary",
      "lcov",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 78,
        "branches": 68,
        "functions": 75,
        "lines": 78
      }
    },
    "testEnvironment": "node"
  }
}
